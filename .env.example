# Yahoo SMTP — copy to .env and fill in (see README)
SMTP_HOST=smtp.mail.yahoo.com
SMTP_PORT=587
SMTP_USER=your_yahoo_address@yahoo.com
SMTP_PASS=your_yahoo_app_password
EMAIL_FROM=your_yahoo_address@yahoo.com
EMAIL_TO=balaji.chandran@yahoo.com

